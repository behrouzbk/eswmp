# Copy to staging.tfvars and fill in real values. Never commit staging.tfvars —
# it is gitignored (*.tfvars). In CI, pass these as -var flags backed by secrets
# instead of committing a file.

environment = "staging"
location    = "canadacentral"
project     = "eswmp"

pg_admin_login    = "eswmpadmin"
pg_admin_password = "REPLACE_ME" # generate with: openssl rand -base64 24

# Must be the exact same value configured on the consuming product's (e.g.
# PetZiv's) token issuer — this is a shared HMAC secret, not a public/private
# keypair. Coordinate this value with that team before applying.
jwt_secret_key = "REPLACE_ME_MIN_64_BYTES"
jwt_issuer     = "eswmp"
jwt_audience   = "eswmp-api"
