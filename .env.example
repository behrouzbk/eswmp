# ============================================================
# ESWMP Environment Variables — EXAMPLE FILE
# Copy to .env and fill in all values before running locally.
# NEVER commit .env — it is gitignored.
# ============================================================

# ---- PostgreSQL (local Docker — postgres:16-alpine) ----
POSTGRES_PASSWORD=YourStrong@Passw0rd

# ---- Connection Strings (PostgreSQL — one DB per service) ----
CORE_DB=Host=localhost;Port=6432;Database=eswmp_core;Username=eswmp;Password=YourStrong@Passw0rd
ASSIGNMENT_DB=Host=localhost;Port=6432;Database=eswmp_assignment;Username=eswmp;Password=YourStrong@Passw0rd
RULES_DB=Host=localhost;Port=6432;Database=eswmp_rules;Username=eswmp;Password=YourStrong@Passw0rd

# ---- Redis ----
REDIS_CONNECTION=localhost:6380,abortConnect=false

# ---- JWT Authentication ----
# Generate with: [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(64))
# ESWMP validates JWTs issued by whatever identity system the embedding product uses
# (it does not issue its own tokens — see docs/ARCHITECTURE.md §Auth Scope).
JWT_SECRET_KEY=REPLACE_WITH_GENERATED_KEY_MIN_64_BYTES
JWT_ISSUER=https://eswmp.dev
JWT_AUDIENCE=eswmp-api

# ---- Application Insights (Observability — optional) ----
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ---- Cross-service URLs (local) ----
CORE_BASE_URL=http://localhost:6001
ASSIGNMENT_BASE_URL=http://localhost:6002
RULES_BASE_URL=http://localhost:6003

# ---- Message Bus (local RabbitMQ) ----
MESSAGEBUS_HOST=localhost
MESSAGEBUS_PORT=6673
MESSAGEBUS_USERNAME=guest
MESSAGEBUS_PASSWORD=guest

# ---- Observability (local Jaeger) ----
OTEL_ENDPOINT=http://localhost:5317
