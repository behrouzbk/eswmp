.env
.env.local
.env.*.local
*.pfx
*.p12
*.pem
*.key
!*.example

# --- .NET / C# ---
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs
.vs/
_ReSharper*/
*.resharper
*.DotSettings.user
[Tt]est[Rr]esult*/
*.ncrunch*
*.opensdf
