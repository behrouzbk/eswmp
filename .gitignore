*.vssscc
.builds
*.svclog
*.scc

# --- Node.js / Frontend (reserved for future frontend) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.eslintcache
.stylelintcache
*.tsbuildinfo
.parcel-cache
.cache
dist/
build/
.vite/
storybook-static/

# --- Generated clients (auto-generated, never hand-edit) ---
clients/generated/

# --- Docker ---
.docker/
docker-compose.override.yml.local

# --- Terraform ---
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfstate.backup
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
*.tfvars
!terraform.tfvars.example

# --- Azure ---
.azure/
azure.json

# --- OS ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# --- IDEs ---
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
.idea/
*.iml
*.ipr
*.iws

# --- Test output ---
TestResults/
coverage/
*.coverage
*.coveragexml
lcov.info

# --- Docs (internal planning documents — never commit) ---
# Exceptions: docs/API and docs/Azure are operational guides meant for remote
# testers/developers and anyone deploying to Azure — those get tracked and
# pushed like normal source. Everything else directly under docs/ (status
# trackers, task boards, planning docs) stays local-only, per the rule above.
# Must be docs/* (not docs/) — negating a subdirectory doesn't work if the
# parent itself is excluded (git's documented gitignore limitation); docs/*
# excludes each immediate child individually instead, which the !docs/API/
# and !docs/Azure/ negations below can then override.
docs/*
!docs/API/
!docs/Azure/

# --- Claude Code local settings ---
.claude/settings.local.json
